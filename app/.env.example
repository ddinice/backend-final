# Copy to app/.env.dev or app/.env.prod (gitignored). Never commit real secrets.
#
# Local smoke with empty DB (creates schema — dev only):
#   SYNC_DB=1
# Production must use SYNC_DB=0 and migrations; never enable sync against prod.

PORT=3000
NODE_ENV=dev

JWT_SECRET=replace_with_at_least_32_chars_random_string
JWT_EXPIRES_IN=15m

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace_me
DB_NAME=postgres

# Behind reverse proxy: forward X-Forwarded-For and set TRUST_PROXY=1
TRUST_PROXY=0

# Optional: only for local dev when no migrations (see security-homework/secret-flow-note.md)
SYNC_DB=0
