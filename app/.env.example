PORT=3000
NODE_ENV=dev

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=5h

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_PREFETCH=10
RABBITMQ_DISABLED=false

ORDER_PROCESS_INLINE=false

PAYMENTS_GRPC_URL=127.0.0.1:50051
PAYMENTS_GRPC_PORT=50051
PAYMENTS_GRPC_DISABLED=false
PAYMENTS_GRPC_DEADLINE_MS=5000
PAYMENTS_DEFAULT_CURRENCY=UAH
